---
const { entry, pixelsPerCm, minBarPx = 36, colorFrom, colorTo, order = 0 } = Astro.props;

const { personaje, tipo, cm, valor, formNombre, hasMultipleForms } = entry;
const barHeight = Math.max(cm * pixelsPerCm, minBarPx);

// Si tiene múltiples formas y existe un nombre válido para la forma, lo agregamos entre paréntesis
const nombreCompleto = hasMultipleForms && formNombre 
  ? `${personaje.nombre} (${formNombre})` 
  : personaje.nombre;
---

<div
  class="height-bar"
  data-height-bar
  data-tipo={tipo}
  data-cm={cm}
  style={`--bar-height:${barHeight}px; --color-from:${colorFrom}; --color-to:${colorTo}; order:${order};`}
>
  <span class="height-bar__value">{valor}</span>

  <div class="height-bar__column">
    {personaje.avatar && (
      <img
        src={personaje.avatar}
        alt={personaje.nombre}
        class="height-bar__avatar"
        loading="lazy"
      />
    )}
  </div>

  <div class="height-bar__name-wrap">
    <span class="height-bar__name" title={nombreCompleto}>{nombreCompleto}</span>
  </div>
</div>

<style>
  .height-bar {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end; /* Mantiene la base alineada */
    width: 120px;
    flex: 0 0 auto;
    /* Reducimos un poco el margen inferior si es necesario */
    padding-bottom: 0.5rem; 
  }


  .height-bar__value {
    height: 1.3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 0.35rem;
    white-space: nowrap;
  }

  .height-bar__column {
    width: 56px;
    height: var(--bar-height);
    border-radius: 0.75rem 0.75rem 0.35rem 0.35rem;
    background: linear-gradient(180deg, var(--color-from), var(--color-to));
    box-shadow: 0 0 18px -4px var(--color-to);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: filter 0.2s ease;
    flex-shrink: 0;
  }

  .height-bar:hover .height-bar__column {
    filter: brightness(1.15);
  }

  .height-bar__avatar {
    width: 44px;
    height: 44px;
    object-fit: cover;
    border-radius: 9999px;
    margin-top: 6px;
    border: 2px solid rgba(255, 255, 255, 0.85);
  }
  .height-bar__name-wrap {
    position: relative;
    margin-top: 0.3rem; /* Reducido de 0.5rem para acercar el texto a la barra */
    width: 100%;
    display: flex;
    justify-content: center;
  }
  .height-bar__name {
    height: 3.8rem;
    display: -webkit-box;
    -webkit-line-clamp: 3; /* Un límite limpio para textos largos con paréntesis */
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.85rem;
    line-height: 1.2;
    text-align: center;
    color: white;
    max-width: 120px;
    cursor: default;
    word-break: break-word;
  }

  @media (max-width: 768px) {
    .height-bar { width: 104px; }
    .height-bar__column { width: 48px; }
    .height-bar__avatar { width: 38px; height: 38px; }
    .height-bar__name { max-width: 104px; font-size: 0.78rem; height: 3.4rem; }
  }

  @media (max-width: 480px) {
    .height-bar { width: 88px; }
    .height-bar__column { width: 40px; }
    .height-bar__avatar { width: 32px; height: 32px; margin-top: 4px; }
    .height-bar__value { height: 1.1rem; font-size: 0.85rem; }
    .height-bar__name { height: 3.1rem; font-size: 0.72rem; line-height: 1.05; max-width: 88px; }
  }

  @media (max-width: 400px) {
    .height-bar { width: 76px; }
    .height-bar__column { width: 36px; }
    .height-bar__avatar { width: 28px; height: 28px; }
    .height-bar__name { max-width: 76px; font-size: 0.66rem; height: 2.9rem; }
  }
</style>