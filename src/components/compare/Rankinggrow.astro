---
// RankingRow.astro
import RankBadge from "./Rankbadge.astro";
import { STAT_LABELS } from "./lib/statsConfig.js";

const { character, statKeys } = Astro.props;
const { nombre, avatar, stats, poder } = character;

const sortAttrs = Object.fromEntries(
  statKeys.map((key) => [`data-sort-${key}`, stats?.[key]?.valor ?? -1])
);
---

<div
  class="break-inside-avoid mb-3 rounded-xl border border-rz-accent/10 bg-rz-bg/40 p-3 flex flex-col gap-2"
  data-row
  data-sort-nombre={nombre}
  data-sort-poder={poder ?? -1}
  {...sortAttrs}
>
  <div class="flex items-center gap-2 min-w-0">
    {avatar && (
      <img
        src={avatar}
        alt={nombre}
        class="w-8 h-8 rounded-full object-cover shrink-0"
        loading="lazy"
      />
    )}
    <span class="min-w-0 break-words font-display text-white text-sm sm:text-base leading-snug">
      {nombre}
    </span>
  </div>

  <div class="flex flex-col gap-1.5">
    {statKeys.map((key) => {
      const entry = stats?.[key];
      const valor = entry?.valor ?? null;
      const rango = entry?.rango ?? null;
      return (
        <div
          class="flex items-center justify-between gap-2"
          data-stat={key}
          style="display:none"
        >
          <span class="text-xs sm:text-sm text-rz-text/60 font-body uppercase tracking-wider truncate">
            {STAT_LABELS[key] ?? key}
          </span>
          <span class="flex items-center gap-2 shrink-0">
            <span
              data-points
              class="text-xs sm:text-sm font-display tabular-nums text-white/70"
              style="display:none"
            >
              {valor ?? "—"}
            </span>
            <RankBadge rank={rango} sortKey={key} />
          </span>
        </div>
      );
    })}

    <div
      class="items-center justify-between gap-2"
      data-power-row
      style="display:none"
    >
      <span class="text-xs sm:text-sm text-rz-text/60 font-body uppercase tracking-wider">
        Poder Total
      </span>
      <span
        data-poder
        class="text-sm sm:text-base font-display font-semibold tabular-nums text-rz-accent"
      >
        {poder != null ? poder.toLocaleString("es") : "—"}
      </span>
    </div>
  </div>
</div>