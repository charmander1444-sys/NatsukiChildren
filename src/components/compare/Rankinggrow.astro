---
// RankingRow.astro
// Una "tarjeta" de personaje (ya no <tr>, para poder fluir en multi-columna).
// Guarda el índice numérico de cada stat en data-sort-<key> para que
// RankingTable pueda ordenar sin re-renderizar.
// Cada stat vive en su propio <span data-stat="key">, oculto salvo el
// seleccionado en el <select> de RankingTable.
// Props: character { id, nombre, avatar, stats }, statKeys (array de strings)

import RankBadge from "./Rankbadge.astro";
import { rankIndex } from "./lib/statsConfig.js";

const { character, statKeys } = Astro.props;

const sortData = Object.fromEntries(
  statKeys.map((k) => [`data-sort-${k}`, rankIndex(character.stats?.[k])])
);
---

<div
  data-row
  data-sort-nombre={character.nombre.toLowerCase()}
  {...sortData}
  class="break-inside-avoid mb-3 flex items-center justify-between gap-3 rounded-xl border border-rz-accent/10 bg-rz-bg/40 px-4 py-3 hover:bg-rz-accent/5 transition-colors"
>
  <div class="flex items-center gap-3 min-w-0">
    {character.avatar && (
      <img
        src={character.avatar}
        alt={character.nombre}
        class="w-9 h-9 rounded-full object-cover shrink-0"
      />
    )}
    <span class="text-base sm:text-lg text-white font-body truncate">
      {character.nombre}
    </span>
  </div>

  <div class="shrink-0">
    {statKeys.map((key) => (
      <span data-stat={key} style="display:none">
        <RankBadge rank={character.stats?.[key]} />
      </span>
    ))}
  </div>
</div>