---
import RankingTable from "./Rankingtable.astro";
import Controles from "./Controles.astro";
import Height from "../size/Height.astro";
import { STAT_LABELS } from "./lib/statsConfig.js";
import { mergeCharacters } from "./lib/mergeCharacters.js";

import characterKids from "../../data/charactersKids.json";
import statsData from "../../data/stats.json";

const { statKeys = Object.keys(STAT_LABELS) } = Astro.props;

const characters = mergeCharacters(characterKids, statsData);
---

<section class="space-y-4">
  <h2 class="font-display text-4xl text-white text-glow text-center">
    Ranking de personajes
  </h2>
  <p class="text-center text-xl text-rz-text/80 font-body">
    Click en cualquier columna para ordenar
  </p>

  <Controles active="ranking" />

  <!-- Mismo contenedor (ancho/padding) para ambos paneles, en pc y móvil -->
  <div class="container mx-auto max-w-6xl px-4 space-y-4 pb-12">
    <div data-view-panel="ranking">
      <RankingTable characters={characters} statKeys={statKeys} />
    </div>

    <div data-view-panel="tamano" style="display:none;">
      <Height personajes={characterKids} />
    </div>
  </div>
</section>

<script>
  document.addEventListener("controles:change", (e) => {
    const { control } = (e as CustomEvent).detail;

    document.querySelectorAll<HTMLElement>("[data-view-panel]").forEach((panel) => {
      panel.style.display = panel.dataset.viewPanel === control ? "" : "none";
    });
  });
</script>