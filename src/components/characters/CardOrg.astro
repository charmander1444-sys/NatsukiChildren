---
import Card from "./Card.astro";

interface Character {
  id: string;
  nombre: string;
  tipo: string;
  avatar?: string;
  [key: string]: any;
}

interface Props {
  characters: Character[];
}

const { characters } = Astro.props;
---

<div
  id="card-grid"
  class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4"
>
  {characters.map((c) => (
    <Card id={c.id} nombre={c.nombre} avatar={c.avatar} tipo={c.tipo} />
  ))}
</div>

<p
  id="no-results"
  class="hidden text-center text-rz-text/50 font-body italic py-16"
>
  No se encontraron personajes.
</p>