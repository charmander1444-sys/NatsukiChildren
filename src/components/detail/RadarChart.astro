---
// RadarChart.astro
import { getRango, RANGOS } from "../../data/lib/stats.js";

// RANGOS es un array de objetos {letra, min}, necesitamos solo las letras
const RANGO_LETRAS = RANGOS.map((r) => r.letra);

interface Props {
  entries: [string, string | number][];
  labels: Record<string, string>;
  ranks: string[];
  rankColors: Record<string, string>;
  id?: string;
}

const { entries: rawEntries, labels, ranks, rankColors, id = "radar" } = Astro.props;

/**
 * Normaliza cada entry a una letra de rango válida, sea cual sea el
 * tipo de dato recibido (número crudo, string numérico o letra ya
 * calculada). Esto hace que el componente sea seguro de usar incluso
 * si en algún punto se le pasan stats sin procesar.
 */
function toRankLetter(rawValue) {
  if (rawValue == null) return null;

  if (typeof rawValue === "object") {
    const upper = String(rawValue.rango ?? "").toUpperCase();
    return RANGO_LETRAS.includes(upper) ? upper : null;
  }

  if (typeof rawValue === "number") return getRango(rawValue);

  const upper = rawValue.toUpperCase();
  if (RANGO_LETRAS.includes(upper)) return upper;

  const parsed = parseFloat(rawValue);
  return Number.isNaN(parsed) ? null : getRango(parsed);
}

const entries: [string, string][] = rawEntries
  .map(([key, rawValue]) => [key, toRankLetter(rawValue)] as [string, string | null])
  .filter((e): e is [string, string] => !!e[1]);

const n = entries.length;
const canRender = n >= 3;

const size = 560;
const center = 280;
const maxR = 170;
const labelR = 225;
const rings = 4;

let svgInner = "";
let points: any[] = [];

if (canRender) {
  points = entries.map(([key, rank], i) => {
    const idx = Math.max(0, ranks.indexOf(rank));
    const norm = (idx + 1) / ranks.length;
    const angle = -Math.PI / 2 + (2 * Math.PI * i) / n;

    return {
      x: center + maxR * norm * Math.cos(angle),
      y: center + maxR * norm * Math.sin(angle),
      labelX: center + labelR * Math.cos(angle),
      labelY: center + labelR * Math.sin(angle),
      axisX: center + maxR * Math.cos(angle),
      axisY: center + maxR * Math.sin(angle),
      color: rankColors[rank] ?? "#8b93b0",
      rank,
      label: labels[key] ?? key,
      angle,
    };
  });

  const polygonPoints = points
    .map((p) => `${p.x.toFixed(1)},${p.y.toFixed(1)}`)
    .join(" ");

  const gridRings = Array.from({ length: rings }, (_, ringIdx) => {
    const ringNorm = (ringIdx + 1) / rings;
    const ringPoints = entries
      .map((_, i) => {
        const angle = -Math.PI / 2 + (2 * Math.PI * i) / n;
        const x = center + maxR * ringNorm * Math.cos(angle);
        const y = center + maxR * ringNorm * Math.sin(angle);
        return `${x.toFixed(1)},${y.toFixed(1)}`;
      })
      .join(" ");
    return `<polygon points="${ringPoints}" fill="none" stroke="#ffffff" stroke-opacity="0.08" stroke-width="1.5" />`;
  }).join("");

  const axisLines = points
    .map(
      (p) => `<line x1="${center}" y1="${center}" x2="${p.axisX.toFixed(1)}" y2="${p.axisY.toFixed(1)}" stroke="#ffffff" stroke-opacity="0.12" stroke-width="1.5" />`
    )
    .join("");

  const vertexDots = points
    .map(
      (p) => `<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="6" fill="${p.color}" stroke="#0a0a12" stroke-width="2" />`
    )
    .join("");

  svgInner = `
    ${gridRings}
    ${axisLines}
    <polygon points="${polygonPoints}" fill="#b48cff" fill-opacity="0.22" stroke="#b48cff" stroke-width="3" />
    ${vertexDots}
  `;
}
---

{canRender ? (
  <div class="relative w-full max-w-[560px] mx-auto" style={`aspect-ratio: 1 / 1;`}>
    <svg
      id={id}
      viewBox="-40 -40 640 640"
      class="w-full h-full block overflow-visible absolute inset-0"
      set:html={svgInner}
    />

    <div class="absolute inset-0 pointer-events-none">
      {points.map((p) => {
        let translateX = "-50%";
        let justify = "center";
        if (Math.cos(p.angle) > 0.3) justify = "start";
        else if (Math.cos(p.angle) < -0.3) justify = "end";

        const toPct = (v: number) => ((v + 40) / 640) * 100;

        return (
          <>
            <span
              class="absolute font-bold text-[16px] -translate-x-1/2 -translate-y-full"
              style={`left:${toPct(p.x)}%; top:${toPct(p.y - 16)}%; color:${p.color};`}
            >
              {p.rank}
            </span>
            <span
              class="absolute text-[16px] font-semibold text-[#e5e0f0] opacity-90 whitespace-nowrap"
              style={`left:${toPct(p.labelX)}%; top:${toPct(p.labelY)}%; transform: translate(${justify === "start" ? "0" : justify === "end" ? "-100%" : "-50%"}, -50%);`}
            >
              {p.label}
            </span>
          </>
        );
      })}
    </div>
  </div>
) : (
  <p class="text-center text-sm text-rz-text/50 font-body py-6">
    Se necesitan al menos 3 stats para el radar.
  </p>
)}