---
import RadarChart from "./RadarChart.astro";

interface StatsPanel {
  id: string;
  nombre: string;
  stats: Record<string, string>;
}

interface Props {
  stats?: Record<string, string> | { panels: StatsPanel[] };
}

const { stats } = Astro.props;

const LABELS: Record<string, string> = {
  fuerza: "Fuerza",
  resistencia: "Resistencia",
  velocidad: "Velocidad",
  inteligencia: "Inteligencia",
  habilidades_combate: "Combate",
  carisma: "Carisma",
  portal: "Puerta",
  afinidad_espiritual: "Afinidad",
  potencial: "Potencial",
  suerte: "Suerte",
};

const RANKS = ["F", "E", "D", "C", "B", "A", "S", "SS", "SS+", "EX"];

const RANK_COLORS: Record<string, string> = {
  F: "#52525b",
  E: "#71717a",
  D: "#8b8398",
  C: "#8b93b0",
  B: "#60a5fa",
  A: "#818cf8",
  S: "#b48cff",
  SS: "#e879f9",
  "SS+": "#f472b6",
  EX: "#facc15",
};

const RANK_GLOW: Record<string, string> = {
  F: "none",
  E: "none",
  D: "none",
  C: "0 0 4px #8b93b055",
  B: "0 0 6px #60a5fa66",
  A: "0 0 8px #818cf877",
  S: "0 0 10px #b48cff88",
  SS: "0 0 12px #e879f999",
  "SS+": "0 0 14px #f472b6aa",
  EX: "0 0 18px #facc15cc",
};

const RANK_DESC: Record<string, string> = {
  F: "Ninguna",
  E: "Mala",
  D: "Débil",
  C: "Media",
  B: "Buena / Superior al promedio",
  A: "Excelente",
  S: "Superior",
  SS: "Élite",
  "SS+": "Divina",
  EX: "Incalculable",
};

function isMultiPanel(s: any): s is { panels: StatsPanel[] } {
  return !!s && Array.isArray(s.panels);
}

const panels: StatsPanel[] = stats
  ? isMultiPanel(stats)
    ? stats.panels
    : [{ id: "default", nombre: "", stats: stats as Record<string, string> }]
  : [];

function getEntries(statsObj: Record<string, string>) {
  return Object.entries(statsObj ?? {}).filter(
    ([, v]) => v && RANKS.includes(v.toUpperCase())
  );
}

const panelNames = panels.map((p) => p.nombre || "Otro panel");
const hasContent = panels.some((p) => getEntries(p.stats).length > 0);
const panelEntries = panels.map((p) => getEntries(p.stats));
const anyRadarAvailable = panelEntries.some((e) => e.length >= 3);
---

{hasContent && (
  <div
    class="@container rounded-2xl border border-rz-accent/20 bg-rz-bg-2/40 p-6"
    data-stats-widget
    data-panel-names={JSON.stringify(panelNames)}
  >
    <div class="flex items-center justify-between gap-3 mb-5 flex-wrap">
      <h2 class="font-display text-xl text-white text-glow flex-1 text-center">
        Stats
      </h2>
      <div class="flex items-center gap-2 shrink-0">
        {anyRadarAvailable && (
          <button
            type="button"
            data-view-toggle
            class="text-xs font-body uppercase tracking-wider px-3 py-1.5 rounded-full border border-rz-accent/30 text-rz-text/70 hover:text-white hover:border-rz-accent/60 transition-colors duration-200"
          >
            Ver radar
          </button>
        )}
        {panels.length > 1 && (
          <button
            type="button"
            data-stats-toggle
            class="text-xs font-body uppercase tracking-wider px-3 py-1.5 rounded-full border border-rz-accent/30 text-rz-text/70 hover:text-white hover:border-rz-accent/60 transition-colors duration-200"
          >
            Ver: {panelNames[1]}
          </button>
        )}
      </div>
    </div>

    {panels.map((panel, i) => {
      const entries = panelEntries[i];
      return (
        <div
          class="space-y-4"
          data-stats-panel
          style={i === 0 ? "" : "display:none"}
        >
          {panel.nombre && panels.length > 1 && (
            <p class="text-center text-xs uppercase tracking-widest text-rz-accent/70 font-body mb-3">
              {panel.nombre}
            </p>
          )}

          <div data-view="bars" class="space-y-4">
            {entries.map(([key, rawRank]) => {
              const rank = rawRank.toUpperCase();
              const idx = RANKS.indexOf(rank);
              const pct = ((idx + 1) / RANKS.length) * 100;
              const color = RANK_COLORS[rank];
              const glow = RANK_GLOW[rank];
              return (
                <div
                  class="flex items-center gap-3 @max-[400px]:flex-wrap @max-[400px]:gap-y-1.5"
                  title={RANK_DESC[rank]}
                >
                  <span class="w-40 shrink-0 text-sm uppercase tracking-wider text-rz-text/70 font-body @max-[400px]:w-auto @max-[400px]:flex-1 @max-[400px]:order-1">
                    {LABELS[key] ?? key}
                  </span>

                  <div class="flex-1 h-3 rounded-full bg-rz-bg/70 overflow-hidden @max-[400px]:basis-full @max-[400px]:order-3">
                    <div
                      class="h-full rounded-full transition-all duration-500"
                      style={`width:${pct}%; background:${color}; box-shadow:${glow};`}
                    ></div>
                  </div>

                  <span
                    class="w-14 shrink-0 text-center text-sm font-display font-semibold rounded-full py-0.5 @max-[400px]:w-auto @max-[400px]:px-2 @max-[400px]:order-2"
                    style={`color:${color}; border:1px solid ${color}55; background:${color}14;`}
                  >
                    {rank}
                  </span>
                </div>
              );
            })}
          </div>

          <div data-view="radar" class="py-2" style="display:none">
            <RadarChart
              entries={entries}
              labels={LABELS}
              ranks={RANKS}
              rankColors={RANK_COLORS}
              id={`radar-${panel.id}-${i}`}
            />
          </div>
        </div>
      );
    })}
  </div>
)}

{(panels.length > 1 || anyRadarAvailable) && (
  <script>
    document.querySelectorAll("[data-stats-widget]").forEach((widget) => {
      const stackBtn = widget.querySelector("[data-stats-toggle]") as HTMLButtonElement | null;
      const viewBtn = widget.querySelector("[data-view-toggle]") as HTMLButtonElement | null;
      const panelEls = Array.from(widget.querySelectorAll("[data-stats-panel]")) as HTMLElement[];
      const names: string[] = JSON.parse(widget.getAttribute("data-panel-names") || "[]");
      let current = 0;
      let viewMode: "bars" | "radar" = "bars";

      function renderPanels() {
        panelEls.forEach((el, i) => {
          el.style.display = i === current ? "" : "none";
        });
        if (stackBtn) {
          const nextIndex = (current + 1) % panelEls.length;
          stackBtn.textContent = `Ver: ${names[nextIndex] ?? "otro panel"}`;
        }
      }

      function renderView() {
        panelEls.forEach((panelEl) => {
          const bars = panelEl.querySelector('[data-view="bars"]') as HTMLElement | null;
          const radar = panelEl.querySelector('[data-view="radar"]') as HTMLElement | null;
          if (bars) bars.style.display = viewMode === "bars" ? "" : "none";
          if (radar) radar.style.display = viewMode === "radar" ? "" : "none";
        });
        if (viewBtn) {
          viewBtn.textContent = viewMode === "bars" ? "Ver radar" : "Ver barras";
        }
      }

      stackBtn?.addEventListener("click", () => {
        current = (current + 1) % panelEls.length;
        renderPanels();
      });

      viewBtn?.addEventListener("click", () => {
        viewMode = viewMode === "bars" ? "radar" : "bars";
        renderView();
      });

      renderPanels();
      renderView();
    });
  </script>
)}