---
interface Props {
  nombre: string;
  avatar?: string;
  tipo?: string;
  alineacion?: string;
  edad?: string;
  tamano?: string;
}

const { nombre, avatar = "", tipo = "", alineacion = "", edad = "", tamano = "" } = Astro.props;

const TIPO_LABEL: Record<string, string> = {
  hija: "Hija",
  hijo: "Hijo",
  sin_genero: "Sin género",
  madre: "Madre",
  raiz: "Padre",
  conexion: "Conexión",
};

const TIPO_COLOR: Record<string, string> = {
  hija: "#f472b6",
  hijo: "#60a5fa",
  sin_genero: "#cbd5e1",
  madre: "#6ee7ff",
  raiz: "#b48cff",
  conexion: "#8b8398",
};

const accent = TIPO_COLOR[tipo] ?? "#b48cff";

const metaItems = [
  alineacion && { label: "Alineación", value: alineacion },
  edad && { label: "Edad", value: edad },
  tamano && { label: "Tamaño", value: tamano },
].filter(Boolean) as { label: string; value: string }[];
---

<div class="rounded-2xl border border-rz-accent/20 bg-rz-bg-2/40 p-6 flex flex-col items-center gap-4">
  <div
    class="relative w-full aspect-square max-w-[280px] rounded-xl overflow-hidden border-2"
    style={`border-color:${accent}88; box-shadow:0 0 25px 4px ${accent}33;`}
  >
    {avatar ? (
      <img src={avatar} alt={nombre} class="w-full h-full object-cover" />
    ) : (
      <div class="w-full h-full bg-black flex items-center justify-center">
        <span class="text-rz-text/20 text-5xl font-display">?</span>
      </div>
    )}
  </div>

  {tipo && (
    <span class="text-sm uppercase tracking-wider font-body" style={`color:${accent}`}>
      {TIPO_LABEL[tipo] ?? tipo}
    </span>
  )}

  {metaItems.length > 0 && (
    <dl class="w-full grid grid-cols-1 gap-1.5 text-center">
      {metaItems.map((item) => (
        <div>
          <dt class="text-xs uppercase tracking-wider text-rz-accent-2/80 font-body">{item.label}</dt>
          <dd class="text-base text-rz-text/85 font-body">{item.value}</dd>
        </div>
      ))}
    </dl>
  )}
</div>