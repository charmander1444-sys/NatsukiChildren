---
interface TamanoItem {
  nombre: string;
  valor: string;
}

interface Props {
  nombre: string;
  avatar?: string;
  tipo?: string;
  alineacion?: string;
  edad?: string;
  tamano?: string | { items: TamanoItem[] };
  cumpleanos?: string;
  signoZodiacal?: string;
}

const {
  nombre,
  avatar = "",
  tipo = "",
  alineacion = "",
  edad = "",
  tamano = "",
  cumpleanos = "",
  signoZodiacal = "",
} = Astro.props;

const TIPO_LABEL: Record<string, string> = {
  hija: "Hija",
  hijo: "Hijo",
  sin_genero: "Sin género",
  madre: "Madre",
  raiz: "Padre",
  conexion: "Conexión",
};

const TIPO_COLOR: Record<string, string> = {
  hija: "#f472b6",
  hijo: "#60a5fa",
  sin_genero: "#cbd5e1",
  madre: "#6ee7ff",
  raiz: "#b48cff",
  conexion: "#8b8398",
};

// Íconos (símbolos astrológicos unicode) por signo zodiacal
const ZODIAC_ICON: Record<string, string> = {
  aries: "♈",
  tauro: "♉",
  geminis: "♊",
  "géminis": "♊",
  cancer: "♋",
  "cáncer": "♋",
  leo: "♌",
  virgo: "♍",
  libra: "♎",
  escorpio: "♏",
  sagitario: "♐",
  capricornio: "♑",
  acuario: "♒",
  piscis: "♓",
};

function normalizeKey(s: string) {
  return s
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .trim();
}

const zodiacIcon = signoZodiacal ? (ZODIAC_ICON[normalizeKey(signoZodiacal)] ?? "✦") : "";

const accent = TIPO_COLOR[tipo] ?? "#b48cff";

function isMultiTamano(t: any): t is { items: TamanoItem[] } {
  return !!t && typeof t === "object" && Array.isArray(t.items);
}

const tamanoIsMulti = isMultiTamano(tamano);
const tamanoSimple = !tamanoIsMulti ? (tamano as string) : "";

const metaItems = [
  alineacion && { label: "Alineación", value: alineacion },
  edad && { label: "Edad", value: edad },
  !tamanoIsMulti && tamanoSimple && { label: "Tamaño", value: tamanoSimple },
].filter(Boolean) as { label: string; value: string }[];
---

<div class="rounded-2xl border border-rz-accent/20 bg-rz-bg-2/40 p-6 flex flex-col items-center gap-4">
  <div
    class="relative w-full aspect-square max-w-[280px] rounded-xl overflow-hidden border-2"
    style={`border-color:${accent}88; box-shadow:0 0 25px 4px ${accent}33;`}
  >
    {avatar ? (
      <button
        type="button"
        class="avatar-thumb group relative w-full h-full block cursor-zoom-in"
        data-src={avatar}
        aria-label={`Ampliar imagen de ${nombre}`}
      >
        <img
          src={avatar}
          alt={nombre}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
      </button>
    ) : (
      <div class="w-full h-full bg-black flex items-center justify-center">
        <span class="text-rz-text/20 text-5xl font-display">?</span>
      </div>
    )}
  </div>

  {tipo && (
    <span class="text-sm uppercase tracking-wider font-body" style={`color:${accent}`}>
      {TIPO_LABEL[tipo] ?? tipo}
    </span>
  )}

  {(cumpleanos || signoZodiacal) && (
    <div
      class="flex items-center gap-3 rounded-xl border px-4 py-2"
      style={`border-color:${accent}44; background:${accent}0d;`}
    >
      {signoZodiacal && (
        <span
          class="text-3xl leading-none"
          style={`color:${accent}`}
          title={signoZodiacal}
          aria-hidden="true"
        >
          {zodiacIcon}
        </span>
      )}
      <div class="text-center sm:text-left">
        {cumpleanos && (
          <p class="text-lg text-rz-text/85 font-body leading-tight">{cumpleanos}</p>
        )}
        {signoZodiacal && (
          <p class="text-sm uppercase tracking-wider text-rz-accent-2/80 font-body leading-tight">
            {signoZodiacal}
          </p>
        )}
      </div>
    </div>
  )}

  {metaItems.length > 0 && (
    <dl class="w-full grid grid-cols-1 gap-1.5 text-center">
      {metaItems.map((item) => (
        <div>
          <dt class="text-sm uppercase tracking-wider text-rz-accent-2/80 font-body">{item.label}</dt>
          <dd class="text-lg text-rz-text/85 font-body">{item.value}</dd>
        </div>
      ))}
    </dl>
  )}

  {tamanoIsMulti && (tamano as { items: TamanoItem[] }).items.length > 0 && (
    <div class="w-full text-center">
      <dt class="text-sm uppercase tracking-wider text-rz-accent-2/80 font-body mb-1.5">
        Tamaño
      </dt>
      <dl class="flex flex-col gap-1.5">
        {(tamano as { items: TamanoItem[] }).items.map((item) => (
          <div class="flex items-center justify-center gap-2 text-base font-body">
            <span class="text-rz-text/80">{item.nombre}:</span>
            <span class="text-rz-text/90 text-lg font-semibold">{item.valor}</span>
          </div>
        ))}
      </dl>
    </div>
  )}

  {avatar && (
    <div
      id="avatar-lightbox"
      class="hidden fixed inset-0 z-50 bg-black/85 backdrop-blur-sm items-center justify-center p-6 cursor-zoom-out"
    >
      <img id="avatar-lightbox-img" src="" alt="" class="max-w-full max-h-full rounded-lg" />
    </div>
  )}
</div>

<script>
  const avatarBtn = document.querySelector<HTMLButtonElement>(".avatar-thumb");
  const lightbox = document.getElementById("avatar-lightbox");
  const lightboxImg = document.getElementById("avatar-lightbox-img") as HTMLImageElement | null;

  avatarBtn?.addEventListener("click", () => {
    if (!lightbox || !lightboxImg) return;
    lightboxImg.src = avatarBtn.dataset.src ?? "";
    lightboxImg.alt = avatarBtn.getAttribute("aria-label") ?? "";
    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
  });

  lightbox?.addEventListener("click", () => {
    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
    if (lightboxImg) lightboxImg.src = "";
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && lightbox && !lightbox.classList.contains("hidden")) {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      if (lightboxImg) lightboxImg.src = "";
    }
  });
</script>