---
/**
 * compare.astro
 * Página que muestra la comparación de alturas de todos los personajes
 * de charactersKids.json.
 *
 * Ajusta las rutas de importación de abajo según la ubicación real
 * de tu Layout y de tu archivo JSON en el proyecto.
 */
import HeightCompareChart from "./Heightcomparechart.astro";

// Import dinámico + try/catch: si la ruta del JSON está mal o el archivo
// no existe ahí, no rompe la página entera; solo deja `personajes` vacío
// y avisa en la consola del servidor con el error real.
let personajes: any[] = [];
try {
  const mod = await import("../../data/charactersKids.json");
  const data = (mod as any).default ?? mod;
  // El JSON viene como { "personas": [...] }, no como array en la raíz.
  // Si en algún momento cambia a un array directo, esto sigue funcionando.
  personajes = Array.isArray(data) ? data : data?.personas ?? [];
} catch (err) {
  console.error(
    "[compare.astro] No se pudo cargar charactersKids.json. Revisa la ruta del import:",
    err
  );
}
---

{personajes.length === 0 && (
  <p class="text-rz-text/50 font-body text-sm">
    No se encontraron personajes. Revisa la consola del servidor: probablemente
    la ruta del import de <code>charactersKids.json</code> no coincide con la
    ubicación real del archivo.
  </p>
)}

<HeightCompareChart personajes={personajes} />