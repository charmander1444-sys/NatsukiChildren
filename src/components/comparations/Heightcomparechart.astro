---
/**
 * HeightCompareChart.astro
 * Estilo "HeightComparison.com": iconos de cuerpo entero parados sobre
 * una línea base, escala real en cm a la izquierda con líneas horizontales
 * de referencia, y una barra deslizante debajo para moverse horizontalmente.
 *
 * Toma el listado completo de personajes (charactersKids.json), aplana
 * las alturas -incluyendo a quienes tienen varias formas, como Phoebe con
 * 3 tamaños distintos- y las ordena de mayor a menor.
 */
import FullBodySilhouette from "./Fullbodysilhouette.astro";

interface TamanoItem {
  nombre: string;
  valor: string;
}

interface Personaje {
  id: string;
  nombre: string;
  tipo: string; // "hija" | "hijo" | "sin_genero" (cualquier otro valor se trata como sin_genero)
  tamano?: string | { items: TamanoItem[] } | null;
}

interface Props {
  personajes?: Personaje[];
}

const { personajes = [] } = Astro.props;

// Extrae el primer número de un string de altura ("163cm" -> 163, "1.68m" -> 168)
function parseAltura(valor: string): number {
  if (!valor) return 0;
  const normalizado = valor.replace(",", ".");
  const match = normalizado.match(/[\d.]+/);
  if (!match) return 0;
  const num = parseFloat(match[0]);
  const esMetros = /m(?!m)/i.test(normalizado) && !/cm/i.test(normalizado);
  return esMetros ? num * 100 : num;
}

interface FlatEntry {
  id: string;
  nombre: string;
  forma: string | null;
  tipo: string;
  altura: number;
}

const entries: FlatEntry[] = personajes.flatMap((p): FlatEntry[] => {
  if (!p.tamano) return [];

  if (typeof p.tamano === "string") {
    const altura = parseAltura(p.tamano);
    if (!altura) return [];
    return [{ id: p.id, nombre: p.nombre, forma: null, tipo: p.tipo, altura }];
  }

  if (Array.isArray(p.tamano.items)) {
    return p.tamano.items.flatMap((item) => {
      const altura = parseAltura(item.valor);
      if (!altura) return [];
      return [
        {
          id: `${p.id}-${item.nombre}`,
          nombre: p.nombre,
          forma: item.nombre,
          tipo: p.tipo,
          altura,
        },
      ];
    });
  }

  return [];
});

// De mayor a menor
entries.sort((a, b) => b.altura - a.altura);

const alturas = entries.map((e) => e.altura);
const maxAlturaReal = alturas.length > 0 ? Math.max(...alturas) : 0;
const minAlturaReal = alturas.length > 0 ? Math.min(...alturas) : 0;

// Elige un "paso" agradable (10, 15, 20, 25, 50, 100...) para las etiquetas
// de la regla, sin importar qué tan grande sea el máximo (ej. el Dragón
// Completo de Phoebe a 750cm).
function niceStep(range: number, targetLines = 8): number {
  if (range <= 0) return 10;
  const rough = range / targetLines;
  const magnitude = Math.pow(10, Math.floor(Math.log10(rough)));
  const residual = rough / magnitude;
  let niceResidual: number;
  if (residual > 5) niceResidual = 10;
  else if (residual > 2) niceResidual = 5;
  else if (residual > 1) niceResidual = 2;
  else niceResidual = 1;
  return niceResidual * magnitude;
}

// La escala arranca en 0 (el suelo) y termina apenas por encima del más
// alto -sin dejar un colchón enorme- para que la diferencia entre
// personajes se note lo más posible dentro del mismo alto de dibujo.
const gridMax = Math.max(10, Math.ceil((maxAlturaReal || 1) / 5) * 5);
const step = niceStep(gridMax, 8);
const ticks = Array.from({ length: Math.floor(gridMax / step) + 1 }, (_, i) => i * step);
const stepPct = (step / gridMax) * 100;
const minorStepPct = stepPct / 4;

// Alto fijo del área de dibujo en px; todas las figuras se escalan en
// proporción a esto, así 0cm queda siempre en la base y gridMax arriba.
const CHART_HEIGHT_PX = 460;
const pxPerCm = CHART_HEIGHT_PX / gridMax;

const COLORS: Record<string, string> = {
  hija: "#f9a8d4",
  hijo: "#7dd3fc",
  sin_genero: "#d1d5db",
};
---

{entries.length > 0 && (
  <section class="mt-10 w-full max-w-full">
    <h2 class="font-display text-2xl text-white text-glow mb-1">
      Comparación de alturas
    </h2>
    <p class="text-sm text-rz-text/60 font-body mb-6">
      Todos los personajes y sus formas, ordenados de mayor a menor altura
      ({minAlturaReal}cm – {maxAlturaReal}cm).
    </p>

    <div
      data-height-chart
      class="w-full max-w-full rounded-2xl border border-rz-accent/20 bg-rz-bg-2/40 p-4 sm:p-6 overflow-hidden"
    >
      <div class="flex w-full min-w-0" style={`height:${CHART_HEIGHT_PX}px`}>
        {/* Regla lateral: fija, no hace scroll */}
        <div class="relative w-12 sm:w-14 shrink-0 select-none">
          <span class="absolute -top-5 right-0 text-[9px] uppercase tracking-widest text-rz-accent-2/40 font-body">
            cm
          </span>
          {ticks.map((v) => (
            <div
              class="absolute right-1 sm:right-2 translate-y-1/2 text-[10px] sm:text-xs text-rz-accent-2/60 font-body"
              style={`bottom:${(v / gridMax) * 100}%`}
            >
              {v}
            </div>
          ))}
        </div>

        {/* Área con scroll horizontal (contenida: no rompe el layout) */}
        <div
          data-scroll-area
          class="relative flex-1 min-w-0 h-full overflow-x-auto overflow-y-hidden height-chart-scrollarea"
        >
          <div
            class="h-full w-max flex items-end gap-5 sm:gap-7 pl-3 pr-8 border-b-2 border-amber-400/70"
            style={`background-image: repeating-linear-gradient(to top, transparent 0, transparent calc(${stepPct}% - 1px), rgba(139,124,246,0.16) calc(${stepPct}% - 1px), rgba(139,124,246,0.16) ${stepPct}%), repeating-linear-gradient(to top, transparent 0, transparent calc(${minorStepPct}% - 1px), rgba(139,124,246,0.06) calc(${minorStepPct}% - 1px), rgba(139,124,246,0.06) ${minorStepPct}%); box-shadow: 0 1px 8px rgba(251,191,36,0.35);`}
          >
            {entries.map((entry) => (
              <div class="relative flex flex-col items-center justify-end h-full w-[76px] sm:w-[94px] shrink-0">
                <div class="mb-1.5 text-center leading-tight">
                  <p class="text-[11px] sm:text-xs font-body text-white truncate max-w-[84px]">
                    {entry.nombre}
                  </p>
                  {entry.forma && (
                    <p
                      class="text-[9px] sm:text-[10px] font-body truncate max-w-[84px]"
                      style={`color:${COLORS[entry.tipo] ?? COLORS.sin_genero}`}
                    >
                      {entry.forma}
                    </p>
                  )}
                  <p
                    class="text-[10px] sm:text-[11px] font-display font-semibold"
                    style={`color:${COLORS[entry.tipo] ?? COLORS.sin_genero}`}
                  >
                    {entry.altura}cm
                  </p>
                </div>
                <FullBodySilhouette tipo={entry.tipo} heightPx={entry.altura * pxPerCm} />
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* Barra deslizante para moverse horizontalmente */}
      <div class="flex mt-3">
        <div class="w-12 sm:w-14 shrink-0"></div>
        <input
          type="range"
          data-scrub
          min="0"
          max="100"
          value="0"
          class="flex-1 min-w-0 height-chart-scrub"
          aria-label="Desplazar la comparación de alturas"
        />
      </div>
    </div>

    {/* Leyenda */}
    <div class="flex flex-wrap gap-4 sm:gap-6 mt-4 text-xs font-body text-rz-text/60">
      <span class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full" style="background:#ec4899"></span>
        Hija
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full" style="background:#38bdf8"></span>
        Hijo
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full" style="background:#9ca3af"></span>
        Sin género
      </span>
    </div>
  </section>
)}

<style>
  /* Oculta la scrollbar nativa: la barra deslizante de abajo la reemplaza */
  .height-chart-scrollarea {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .height-chart-scrollarea::-webkit-scrollbar {
    display: none;
  }

  /* Estilo de la barra deslizante */
  .height-chart-scrub {
    -webkit-appearance: none;
    appearance: none;
    height: 6px;
    border-radius: 999px;
    background: rgba(139, 124, 246, 0.2);
    outline: none;
    cursor: pointer;
  }
  .height-chart-scrub::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 999px;
    background: #b48cff;
    box-shadow: 0 0 8px rgba(180, 140, 255, 0.7);
    cursor: pointer;
  }
  .height-chart-scrub::-moz-range-thumb {
    width: 16px;
    height: 16px;
    border: none;
    border-radius: 999px;
    background: #b48cff;
    box-shadow: 0 0 8px rgba(180, 140, 255, 0.7);
    cursor: pointer;
  }
</style>

<script>
  function initHeightCharts() {
    document.querySelectorAll("[data-height-chart]").forEach((chart) => {
      const scrollArea = chart.querySelector("[data-scroll-area]") as HTMLElement | null;
      const slider = chart.querySelector("[data-scrub]") as HTMLInputElement | null;
      if (!scrollArea || !slider) return;

      function syncSliderRange() {
        const maxScroll = Math.max(0, scrollArea!.scrollWidth - scrollArea!.clientWidth);
        slider!.max = String(maxScroll);
        if (Number(slider!.value) > maxScroll) slider!.value = String(maxScroll);
        // Si no hay nada que desplazar, oculta la barra
        if (maxScroll <= 1) {
          slider!.parentElement?.classList.add("hidden");
        } else {
          slider!.parentElement?.classList.remove("hidden");
        }
      }

      syncSliderRange();
      window.addEventListener("resize", syncSliderRange);

      slider.addEventListener("input", () => {
        scrollArea.scrollLeft = Number(slider.value);
      });

      scrollArea.addEventListener("scroll", () => {
        slider.value = String(scrollArea.scrollLeft);
      });
    });
  }

  initHeightCharts();
  document.addEventListener("astro:page-load", initHeightCharts);
</script>