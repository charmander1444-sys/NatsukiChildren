---
// GalleryGrid.astro
// Responsabilidad única: renderizar las imágenes, aplicar el filtro que
// recibe por evento "gallery:search" y el corte de página que recibe por
// "gallery:goto-page". Informa hacia afuera cuántas páginas hay mediante
// "gallery:pages-changed". No sabe nada de cómo se dibuja la paginación.

interface FlatImage {
  id: string;
  personaje: string;
  artista: string;
  src: string;
}

interface Props {
  images: FlatImage[];
}

const { images } = Astro.props;
---

{images.length > 0 && (
  <section class="mt-2">
    <div
      id="gallery-grid"
      class="gallery-grid grid grid-cols-4 sm:grid-cols-3 gap-3"
      data-total={images.length}
    >
      {images.map(({ id, src, personaje, artista }) => (
        <div
          class="gallery-item flex flex-col gap-1.5"
          data-id={id}
          data-personaje={personaje}
          data-artista={artista}
        >
          <button
            type="button"
            class="gallery-thumb group relative aspect-square rounded-lg overflow-hidden border border-rz-accent/20 hover:border-rz-accent/50 transition-colors duration-200"
            data-src={src}
          >
            <img
              src={src}
              alt={personaje}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </button>
          <p class="text-sm text-center text-rz-accent-2/80 font-body truncate">
            {personaje} · {artista}
          </p>
        </div>
      ))}
    </div>

    <p
      id="gallery-no-results"
      class="hidden text-center text-rz-text/60 font-body mt-8"
    >
      No se encontraron imágenes para esa búsqueda.
    </p>

    <div
      id="gallery-lightbox"
      class="hidden fixed inset-0 z-50 bg-black/85 backdrop-blur-sm items-center justify-center p-6 cursor-zoom-out"
    >
      <img id="gallery-lightbox-img" src="" alt="" class="max-w-full max-h-full rounded-lg" />
    </div>
  </section>
)}

<script>
  const grid = document.getElementById("gallery-grid");
  const items = Array.from(document.querySelectorAll(".gallery-item"));
  const noResults = document.getElementById("gallery-no-results");

  const DESKTOP_PAGE_SIZE = 12;
  const MOBILE_PAGE_SIZE = 20;
  const MOBILE_BREAKPOINT = 400;

  let pageSize = DESKTOP_PAGE_SIZE;
  let currentPage = 1;
  let currentQuery = "";
  let filteredItems = items;

  const normalize = (s) =>
    (s ?? "")
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");

  function getPageSize() {
    return window.innerWidth <= MOBILE_BREAKPOINT ? MOBILE_PAGE_SIZE : DESKTOP_PAGE_SIZE;
  }

  function applyFilter() {
    const q = normalize(currentQuery);
    filteredItems = items.filter((item) => {
      if (!q) return true;
      const personaje = normalize(item.dataset.personaje);
      const artista = normalize(item.dataset.artista);
      return personaje.includes(q) || artista.includes(q);
    });
    currentPage = 1;
    renderPage();
  }

  function totalPages() {
    return Math.max(1, Math.ceil(filteredItems.length / pageSize));
  }

  function renderPage() {
    const start = (currentPage - 1) * pageSize;
    const end = start + pageSize;
    const visibleSet = new Set(filteredItems.slice(start, end));

    items.forEach((item) => {
      const isFiltered = filteredItems.includes(item);
      const isVisiblePage = visibleSet.has(item);
      item.style.display = isFiltered && isVisiblePage ? "" : "none";
    });

    noResults?.classList.toggle("hidden", filteredItems.length !== 0);

    document.dispatchEvent(
      new CustomEvent("gallery:pages-changed", {
        detail: { totalPages: totalPages(), currentPage },
      })
    );
  }

  document.addEventListener("gallery:request-state", () => {
    document.dispatchEvent(
      new CustomEvent("gallery:pages-changed", {
        detail: { totalPages: totalPages(), currentPage },
      })
    );
  });

  document.addEventListener("gallery:search", (e) => {
    currentQuery = e.detail?.query ?? "";
    applyFilter();
  });

  document.addEventListener("gallery:goto-page", (e) => {
    const page = e.detail?.page ?? 1;
    const pages = totalPages();
    currentPage = Math.min(Math.max(1, page), pages);
    renderPage();
    grid?.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  let resizeTimeout;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      const newSize = getPageSize();
      if (newSize === pageSize) return;
      const firstVisibleIndex = (currentPage - 1) * pageSize;
      pageSize = newSize;
      currentPage = Math.floor(firstVisibleIndex / pageSize) + 1;
      renderPage();
    }, 150);
  });

  // Lightbox
  const lightbox = document.getElementById("gallery-lightbox");
  const lightboxImg = document.getElementById("gallery-lightbox-img");

  grid?.addEventListener("click", (e) => {
    const btn = e.target.closest(".gallery-thumb");
    if (!btn || !lightbox || !lightboxImg) return;
    lightboxImg.src = btn.dataset.src ?? "";
    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
  });

  lightbox?.addEventListener("click", () => {
    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
    if (lightboxImg) lightboxImg.src = "";
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && lightbox && !lightbox.classList.contains("hidden")) {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      if (lightboxImg) lightboxImg.src = "";
    }
  });

  if (items.length > 0) {
    pageSize = getPageSize();
    // Se retrasa un tick: así GalleryPagination (que se monta después en el DOM)
    // ya tiene su listener de "gallery:pages-changed" registrado cuando
    // disparamos el estado inicial. Sin esto, el primer evento se pierde
    // y la paginación no aparece hasta la primera búsqueda.
    setTimeout(() => applyFilter(), 0);
  }
</script>