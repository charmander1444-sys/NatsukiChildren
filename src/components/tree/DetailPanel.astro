---
// DetailPanel.astro — panel lateral/bottom-sheet que muestra la ficha del personaje seleccionado
---

<div
  id="detail-backdrop"
  class="fixed inset-0 z-40 bg-black/60 backdrop-blur-sm
  opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<aside
  id="detail-panel"
  class="fixed sm:absolute z-50
  bottom-0 left-0 right-0 sm:top-4 sm:right-4 sm:left-auto sm:bottom-auto
  w-full sm:w-80
  max-h-[85vh] sm:max-h-[calc(100%-2rem)]
  overflow-y-auto
  rounded-t-2xl sm:rounded-xl
  border border-rz-accent/30 bg-rz-bg/95 backdrop-blur-md
  p-5 pb-8 sm:pb-5
  shadow-[0_-10px_40px_rgba(0,0,0,0.4)] sm:shadow-[0_0_30px_rgba(180,140,255,0.15)]
  opacity-0 translate-y-full sm:translate-y-0 sm:translate-x-4
  pointer-events-none
  transition-all duration-300 ease-out"
>
  <!-- Handle visual de bottom-sheet, solo en mobile -->
  <div class="sm:hidden w-10 h-1 rounded-full bg-rz-text/25 mx-auto mb-3"></div>

  <button
    id="close-panel"
    aria-label="Cerrar panel de detalles"
    class="absolute top-3 right-3 w-9 h-9 flex items-center justify-center rounded-full
    text-rz-text/60 hover:text-white hover:bg-rz-accent/15 active:scale-95
    transition-all text-2xl leading-none"
  >
    &times;
  </button>

  <div id="detail-content"></div>
</aside>