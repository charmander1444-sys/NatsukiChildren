---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/arbol-genealogico", label: "Arbol Genealogico" },
  {
    href: "/personajes",
    label: "Personajes",
    children: [
      { href: "/personajes", label: "Fichas de personajes" },
      { href: "/calendario", label: "Calendario" },
    ],
  },
  { href: "/galeria", label: "Galeria" },
  { href: "/comparation", label: "Comparacion" },
  {href: "/teatro", label: "Teatro"}
];

const isActive = (href: string) =>
  currentPath === href || currentPath.startsWith(`${href}/`);

const isParentActive = (link: (typeof links)[number]) =>
  isActive(link.href) ||
  (link.children?.some((c) => isActive(c.href)) ?? false);
---

<header class="sticky top-0 z-50 w-full border-b border-rz-accent/15 bg-rz-bg/90 shadow-[0_10px_30px_rgba(0,0,0,0.25)] backdrop-blur-xl">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">

    <a
      href="/"
      class="font-display text-2xl font-semibold tracking-[0.2em] text-white transition-transform duration-300 hover:scale-[1.02]"
    >
      <span class="text-white">Re</span><span class="text-rz-accent">:Zero</span>
    </a>

    <button
      class="flex cursor-pointer flex-col gap-[5px] border-0 bg-transparent p-1 md:hidden"
      id="navToggle"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span class="h-0.5 w-6 rounded-sm bg-white"></span>
      <span class="h-0.5 w-6 rounded-sm bg-white"></span>
      <span class="h-0.5 w-6 rounded-sm bg-white"></span>
    </button>

    <nav
      id="navLinks"
      class="absolute inset-x-0 top-full hidden flex-col border-b border-rz-accent/15 bg-rz-bg/95 px-4 py-4 shadow-lg backdrop-blur-md md:static md:flex md:flex-row md:items-center md:gap-6 md:border-0 md:bg-transparent md:p-0 md:shadow-none"
    >
      {
        links.map((link) =>
          link.children ? (
            <div class="nav-dropdown relative w-full md:w-auto">
              <div class="flex w-full items-center justify-between md:w-auto md:justify-start">

                <a
                  href={link.href}
                  class:list={[
                    "relative rounded-full px-2 py-1.5 text-sm font-semibold uppercase tracking-[0.2em] text-rz-text/80 no-underline transition-all duration-300 sm:text-base",
                    "after:absolute after:left-1/2 after:-bottom-0.5 after:h-0.5 after:w-0 after:-translate-x-1/2 after:bg-gradient-to-r after:from-rz-accent after:to-rz-accent-2 after:transition-all after:duration-300 after:content-['']",
                    isParentActive(link)
                      ? "text-rz-accent after:w-full"
                      : "hover:text-rz-accent hover:after:w-full",
                  ]}
                >
                  {link.label}
                </a>

                <button
                  type="button"
                  class="dropdown-toggle flex items-center justify-center rounded-full p-2 text-rz-text/70 transition-colors duration-200 hover:bg-rz-accent/10 hover:text-rz-accent"
                  aria-label={`Abrir submenú de ${link.label}`}
                  aria-expanded="false"
                >
                  <svg
                    class="dropdown-arrow h-5 w-5 shrink-0 transition-transform duration-200 sm:h-6 sm:w-6"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M5.23 7.21a.75.75 0 011.06.02L10 11.148l3.71-3.918a.75.75 0 111.08 1.04l-4.24 4.48a.75.75 0 01-1.08 0l-4.24-4.48a.75.75 0 01.02-1.06z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </button>
              </div>

              <div
                class="dropdown-menu absolute left-0 top-full z-50 mt-1.5 hidden w-full min-w-[200px] flex-col gap-1 rounded-xl border border-rz-accent/15 bg-rz-bg-2/95 py-2 shadow-xl backdrop-blur-md md:w-max"
              >
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      "block whitespace-nowrap rounded-lg px-4 py-2.5 text-sm font-semibold uppercase tracking-wider no-underline transition-colors duration-200",
                      isActive(child.href)
                        ? "text-rz-accent"
                        : "text-rz-text/80 hover:bg-rz-accent/10 hover:text-rz-accent",
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                "relative rounded-full px-2 py-1.5 text-sm font-semibold uppercase tracking-[0.2em] text-rz-text/80 no-underline transition-all duration-300 sm:text-base",
                "after:absolute after:left-1/2 after:-bottom-0.5 after:h-0.5 after:w-0 after:-translate-x-1/2 after:bg-gradient-to-r after:from-rz-accent after:to-rz-accent-2 after:transition-all after:duration-300 after:content-['']",
                isActive(link.href)
                  ? "text-rz-accent after:w-full"
                  : "hover:text-rz-accent hover:after:w-full",
              ]}
            >
              {link.label}
            </a>
          )
        )
      }
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("navToggle");
  const nav = document.getElementById("navLinks");

  if (toggle && nav) {
    toggle.addEventListener("click", () => {
      const willShow = nav.classList.contains("hidden");
      nav.classList.toggle("hidden", !willShow);
      nav.classList.toggle("flex", willShow);
      toggle.setAttribute("aria-expanded", String(willShow));
    });

    nav.querySelectorAll(":scope > a").forEach((link) => {
      link.addEventListener("click", () => {
        if (window.innerWidth < 768) {
          nav.classList.add("hidden");
          nav.classList.remove("flex");
          toggle.setAttribute("aria-expanded", "false");
        }
      });
    });
  }

  document.querySelectorAll(".nav-dropdown").forEach((dropdown) => {
    const btn = dropdown.querySelector(".dropdown-toggle");
    const menu = dropdown.querySelector(".dropdown-menu");
    const arrow = dropdown.querySelector(".dropdown-arrow");

    const closeMenu = () => {
      menu?.classList.add("hidden");
      menu?.classList.remove("flex");
      arrow?.classList.remove("rotate-180");
      btn?.setAttribute("aria-expanded", "false");
    };

    const openMenu = () => {
      menu?.classList.remove("hidden");
      menu?.classList.add("flex");
      arrow?.classList.add("rotate-180");
      btn?.setAttribute("aria-expanded", "true");
    };

    btn?.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();

      const isOpen = !menu?.classList.contains("hidden");

      document.querySelectorAll(".dropdown-menu").forEach((m) => {
        if (m !== menu) {
          m.classList.add("hidden");
          m.classList.remove("flex");
        }
      });

      isOpen ? closeMenu() : openMenu();
    });

    menu?.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => {
        closeMenu();

        if (window.innerWidth < 768) {
          nav?.classList.add("hidden");
          nav?.classList.remove("flex");
          toggle?.setAttribute("aria-expanded", "false");
        }
      });
    });
  });

  document.addEventListener("click", (e) => {
    document.querySelectorAll(".nav-dropdown").forEach((dropdown) => {
      if (!dropdown.contains(e.target)) {
        const menu = dropdown.querySelector(".dropdown-menu");
        const arrow = dropdown.querySelector(".dropdown-arrow");
        const btn = dropdown.querySelector(".dropdown-toggle");

        menu?.classList.add("hidden");
        menu?.classList.remove("flex");
        arrow?.classList.remove("rotate-180");
        btn?.setAttribute("aria-expanded", "false");
      }
    });
  });
</script>